    {
      "name": "base",
      "hidden": true,
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "description": "Base configuration for all presets"
    },
    {
      "name": "backend-onnx",
      "hidden": true,
      "description": "Select ONNX Runtime as inference backend (x86 dev / cross-compile debug)",
      "cacheVariables": {
        "INFERENCE_BACKEND": "onnx"
      }
    },
    {
      "name": "backend-rknn-zerocopy",
      "hidden": true,
      "description": "Select RKNN zero-copy inference backend (production path for RK3588/RV1126)",
      "cacheVariables": {
        "INFERENCE_BACKEND": "rknn-zerocopy"
      }
    },
    {
      "name": "backend-rknn-non-zerocopy",
      "hidden": true,
      "description": "Select RKNN non-zero-copy inference backend (debug / profiling on-device)",
      "cacheVariables": {
        "INFERENCE_BACKEND": "rknn-non-zerocopy"
      }
    },
    {
      "name": "cfg-debug",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "cfg-release",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "cfg-shared",
      "hidden": true,
      "cacheVariables": {
        "BUILD_SHARED_LIBS": "ON"
      }
    },
    {
      "name": "cfg-static",
      "hidden": true,
      "cacheVariables": {
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "plat-native",
      "hidden": true,
      "description": "Native Host Build",
      "cacheVariables": {
        "CMAKE_PLATFORM": "x86-64;native"
      }
    },
    {
      "name": "plat-rk3588s",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/rk3588s.cmake",
        "CMAKE_PLATFORM": "aarch64;rockchip;rk3588s"
      }
    },
    {
      "name": "plat-rv1126bp",
