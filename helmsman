main(){
    # Preparation -- 1. ENV setup
    func_2_0_setup_env

    # Preparation -- 2. Argument Parsing
    local COMMAND=""
    local ARGS=()

    for arg in "$@"; do
        case $arg in
        -h | --help)
            func_1_7_usage; exit 0 ;;
        -v)
            export V=1; func_2_0_setup_env ;; # Reload env to apply verbose
        *)
            if [ -z "$COMMAND" ]; then COMMAND="$arg"; else ARGS+=("$arg"); fi ;;
        esac
    done

    COMMAND=${COMMAND:-"menu"}


    # Processing -- 1. Main Loop
    case $COMMAND in
        prepare)
            func_3_2_setup_dep_before_build ;;
        convert)
            func_2_1_check_env_ready && func_4_1_ckpt_2_onnx ;;
        inference)
            func_2_1_check_env_ready && func_4_2_inference_with_onnx ;;
        build)
            # func_2_1_check_env_ready && func_4_3_build_cpp "${ARGS[@]}" ;;

            func_4_3_build_dispatch "${ARGS[@]}"
            ;;
        golden)
            func_2_1_check_env_ready && func_4_5_generate_golden_interactive ;;
        clean)
            func_5_1_clean_project ;;
        menu)
            while true; do
                echo ""
                func_1_1_log "--- Helmsman Project Main Menu ---" "blue"
                echo "1. Prepare Environment"
                echo "2. Convert .ckpt model to .onnx"
                echo "3. Run Python inference"
                echo "4. Generate Golden Files (Interactive)"
                echo "5. Build C++ Helmsman Engine"
                echo "6. Clean build"
                echo "7. Clean all(build/venv/models/MODNet SDK etc)"
                echo "8. Exit"
                read -p "   Select [1-6]: " choice
                case $choice in
                    1) func_3_2_setup_dep_before_build ;;
                    2) func_2_1_check_env_ready && func_4_1_ckpt_2_onnx ;;
                    3) func_2_1_check_env_ready && func_4_2_inference_with_onnx ;;
                    4) func_2_1_check_env_ready && func_4_5_generate_golden_interactive ;;
                    5) func_4_4_menu_cpp_build ;;
                    6) func_5_1_clean_project ;;
                    7) func_5_1_clean_project 2;;
                    8) func_1_1_log "👋 Exiting." "green"; exit 0 ;;
                    *) func_1_1_log "Invalid choice." "red" ;;
                esac
            done
            ;;
        *)
            func_1_2_err "Unknown command '$COMMAND'. Use -h for help." ;;
    esac
}

main "$@"