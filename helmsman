#!/bin/bash

# ===================================================================================
#   Helmsman Project - Unified Entry Point
# ===================================================================================

# 1. 定义项目根目录 (最关键的一步，保证所有子脚本都能找到位置)
export ENTRY_SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
export REPO_TOP_DIR="$(dirname "${ENTRY_SCRIPT_PATH}")"
export SCRIPTS_DIR="${REPO_TOP_DIR}/scripts"

# 2. 模块加载器 (Source 模式，解决环境变量共享问题)
#    这样子脚本里定义的 func_ 可以在这里直接用，
#    这里定义的 REPO_TOP_DIR 子脚本也能直接用。
source "${SCRIPTS_DIR}/common.sh"
source "${SCRIPTS_DIR}/setup.sh"
source "${SCRIPTS_DIR}/python_ops.sh"
source "${SCRIPTS_DIR}/cpp_build.sh"
source "${SCRIPTS_DIR}/menus.sh"

# ==============================================================================
# Main Entry Point
# ==============================================================================

main(){
    # Preparation -- 1. ENV setup (Defined in common.sh)
    # 注意：func_2_0 现在只负责设置那些具体的路径变量，根路径由上面设好了
    func_2_0_setup_env

    # Preparation -- 2. Argument Parsing
    local COMMAND=""
    local ARGS=()

    for arg in "$@"; do
        case $arg in
        -h | --help)
            func_1_7_usage; exit 0 ;;
        -v)
            export V=1; func_2_0_setup_env ;; # Reload env to apply verbose
        *)
            if [ -z "$COMMAND" ]; then COMMAND="$arg"; else ARGS+=("$arg"); fi ;;
        esac
    done

    COMMAND=${COMMAND:-"menu"}
    local cmd_lower_case=$(echo "$COMMAND" | tr '[:upper:]' '[:lower:]')

    # Processing -- 1. Main Loop
    case $cmd_lower_case in
        "pre" | "prepare")
            func_3_2_setup_dep_before_build ;;
        "conv" | "cvt" | "convert")
            func_2_1_check_env_ready && func_4_1_ckpt_2_onnx ;;
        "inf" | "inference")
            func_2_1_check_env_ready && func_4_2_inference_with_onnx ;;
        "b" | "build")
            func_2_1_check_env_ready
            # 注意：ARGS 数组传递给 C++ 模块
            func_8_1_cpp_build_dispatch "${ARGS[@]}"
            ;;
        "g" | "golden")
            func_2_1_check_env_ready && func_4_5_generate_golden_interactive ;;
        "c" | "clean")
            func_5_1_clean_project ;;
        "ca" | "cleanall")
            func_5_1_clean_project 2;;
        "menu")
            func_9_1_main_menu_entry ;; # 这里的菜单入口稍微改个名，逻辑在 menus.sh
        *)
            func_1_2_err "Unknown command '$COMMAND'. Use -h for help." ;;
    esac
}

# 启动
main "$@"