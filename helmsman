func_5_4_finalize() {
    # (From B) - The "magic" reporting at the end
    local exit_code=$?
    local final_time=$(func_1_3_get_current_milliseconds)

    echo "" # New line for visual separation
    if [[ -n "${__START_TIME:-}" ]]; then
