func_2_1_check_env_ready(){
    # (From A) Lightweight check
    if [ ! -d "$LV1_VENV_DIR" ]; then
        func_1_1_log "❌ Environment not ready. Virtual environment not found at '$LV1_VENV_DIR'." "red"
        func_1_1_log "   Please run './helmsman prepare' first." "yellow"
        exit 1
    else
        source ${LV1_VENV_DIR}/bin/activate
        func_1_1_log "✅Activate Python venv Successfully." "green"
    fi
    if [ ! -f "$PYTHON_BIN" ]; then
        func_1_1_log "❌ Python binary not found in venv." "red"
        exit 1
    fi

    # --- 2. Check Essential Links/Files (New Logic) ---
    # func_1_1_log "🔎 Verifying file integrity..." "blue"

    local missing_count=0
    # List of critical files that MUST exist at the destination
    # These match the targets in func_3_0_setup_modnet_softlinks
    local required_files=(
        "${LV4_MODNET_SDK_DIR}/onnx/export_onnx.py"
        "${LV4_MODNET_SDK_DIR}/onnx/inference_onnx.py"
        "${LV4_MODNET_SDK_DIR}/onnx/generate_golden_files.py"
        "${LV4_MODNET_SDK_DIR}/pretrained/mobilenetv2_human_seg.ckpt"
        "${LV4_MODNET_SDK_DIR}/pretrained/modnet_photographic_portrait_matting.ckpt"
        "${LV4_MODNET_SDK_DIR}/pretrained/modnet_photographic_portrait_matting.onnx"
        "${LV4_MODNET_SDK_DIR}/pretrained/modnet_webcam_portrait_matting.ckpt"
    )

    for target_file in "${required_files[@]}"; do
        if [ ! -f "$target_file" ]; then
            # -f returns false if file is missing OR if it's a broken symlink
            func_1_1_log "❌ Missing or broken link: $target_file" "red"
            missing_count=$((missing_count + 1))
        fi
    done

    if [ $missing_count -gt 0 ]; then
        func_1_1_log "   Found $missing_count missing essential file(s)." "yellow"
        func_1_1_log "   Please run './helmsman prepare' to restore symbolic links." "yellow"
        exit 1
    fi

    # func_1_1_log "✅ Environment and links are ready." "green"

}

