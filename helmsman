            func_1_1_log "  MODNet SDK Has been deleted." "green"
        else
            func_1_1_log "  MODNet SDK not exist. Remove Skipped." "green"
        fi
    }

    local clean_choice="$1"
    func_1_1_log "clean_choice=${clean_choice}"
    case $clean_choice in
