func_5_1_clean_project(){
    # # (Merged A & B)
    # func_1_1_log "🧹 Cleanup Options:" "blue"
    # echo "   1. Generated models (.onnx)"
    # echo "   2. Virtual Environment (.venv)"
    # echo "   3. Full Clean (All of above)"
